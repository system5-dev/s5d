<?xml version="1.0" encoding="UTF-8"?>
<!--
  phpunit.xml — generated by unit-tests skill.
  Coverage threshold: {{THRESHOLD}}%. Enforce via vendor/bin/coverage-check after run.
-->
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="https://schema.phpunit.de/11.0/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
         executionOrder="random"
         failOnRisky="true"
         failOnWarning="true">
    <testsuites>
        <testsuite name="unit">
            <directory>tests/Unit</directory>
            <directory>tests</directory>
        </testsuite>
    </testsuites>

    <source>
        <include>
            <directory>src</directory>
        </include>
        <exclude>
            <directory>src/Migrations</directory>
        </exclude>
    </source>

    <coverage>
        <report>
            <cobertura outputFile="test-reports/php/coverage.xml"/>
            <html outputDirectory="test-reports/php/coverage_html"/>
            <clover outputFile="test-reports/php/coverage.clover"/>
        </report>
    </coverage>

    <logging>
        <junit outputFile="test-reports/php/junit.xml"/>
    </logging>
</phpunit>
