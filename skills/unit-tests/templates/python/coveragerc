# .coveragerc — generated by unit-tests skill.
[run]
source = .
branch = True
omit =
    */tests/*
    */test_*.py
    */*_test.py
    */__init__.py
    */migrations/*
    */.venv/*
    */setup.py

[report]
exclude_also =
    pragma: no cover
    raise NotImplementedError
    if __name__ == .__main__.:
    if TYPE_CHECKING:
    \.\.\.
fail_under = {{THRESHOLD}}
show_missing = True
skip_covered = True
