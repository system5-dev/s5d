{
  "description": "S5D plugin hooks — pure-Rust enforcement (S5D-Spec: feat.s5d.pretool-enforcement). Rust subcommands invoked directly; no bash wrappers.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "s5d update check --hook",
            "timeout": 10000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "s5d hook pretool-edit",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/pre-commit-validate.sh",
            "timeout": 30000
          },
          {
            "type": "command",
            "command": "s5d hook require-spec",
            "timeout": 10000
          }
        ]
      }
    ],
    "BeforeTool": [
      {
        "matcher": "run_shell_command",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${extensionPath}/hooks/pre-commit-validate.sh",
            "timeout": 30000
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "s5d hook user-prompt-submit",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
