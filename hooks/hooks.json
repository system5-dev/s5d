{
  "description": "S5D plugin hooks — pure-Rust enforcement chain (S5D-Spec: feat.s5d.pretool-enforcement). All hooks invoke Rust subcommands directly; zero shell wrappers.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "s5d update check --hook",
            "timeout": 10000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "s5d hook pretool-edit",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "s5d hook pre-commit-validate",
            "timeout": 30000
          },
          {
            "type": "command",
            "command": "s5d hook require-spec",
            "timeout": 10000
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "s5d hook user-prompt-submit",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
